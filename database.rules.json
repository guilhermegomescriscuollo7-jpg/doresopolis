{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",

    "config": {
      ".read": true,
      ".write": "auth != null && root.child('contas_secretaria').child(auth.uid).exists()"
    },

    "avisos": {
      ".read": true,
      ".write": "auth != null && root.child('contas_secretaria').child(auth.uid).exists()",
      ".indexOn": "dataPublicacao"
    },

    "horarios_transporte": {
      ".read": true,
      ".write": "auth != null && root.child('contas_secretaria').child(auth.uid).exists()"
    },

    "contas_secretaria": {
      ".read": "auth != null",
      ".write": "!data.exists() || (auth != null && root.child('contas_secretaria').child(auth.uid).child('secretaria').val() === 'ti')"
    },

    "usuarios": {
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "inscricoes_transporte": {
      "$id": {
        ".validate": "newData.child('uid').val() === auth.uid || root.child('contas_secretaria').child(auth.uid).exists()"
      }
    },

    "solicitacoes_obras":    { ".indexOn": ["dataRegistro", "uid"], "$id": { ".validate": "newData.child('uid').val() === auth.uid || root.child('contas_secretaria').child(auth.uid).exists()" } },
    "solicitacoes_saude":    { ".indexOn": ["dataRegistro", "uid"], "$id": { ".validate": "newData.child('uid').val() === auth.uid || root.child('contas_secretaria').child(auth.uid).exists()" } },
    "solicitacoes_educacao": { ".indexOn": ["dataRegistro", "uid"], "$id": { ".validate": "newData.child('uid').val() === auth.uid || root.child('contas_secretaria').child(auth.uid).exists()" } },
    "solicitacoes_tributos": { ".indexOn": ["dataRegistro", "uid"], "$id": { ".validate": "newData.child('uid').val() === auth.uid || root.child('contas_secretaria').child(auth.uid).exists()" } }
  }
}
